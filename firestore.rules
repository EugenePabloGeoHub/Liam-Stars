rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - username: string (required) - Unique username
    //   - displayName: string (optional) - User's display name
    //   - photoURL: string (optional) - User's profile picture URL
    //   - createdAt: timestamp (required) - Account creation timestamp
    //
    // Collection: games
    // Document ID: gameId (random)
    // Fields:
    //   - id: string (required) - Unique game ID
    //   - title: string (required) - Title of the game
    //   - code: string (required) - The generated code for the game
    //   - authorId: string (required) - UID of the creator
    //   - authorName: string (required) - Username of the creator
    //   - likes: number (required) - Number of likes
    //   - views: number (required) - Number of views
    //   - createdAt: timestamp (required) - Game creation timestamp
    //
    // Collection: games/{gameId}/likes
    // Document ID: userId (UID)
    // Fields:
    //   - userId: string (required) - UID of the user who liked
    //   - gameId: string (required) - ID of the game liked
    //   - createdAt: timestamp (required) - Like timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "liamrybolt@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 50)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500));
    }

    function isValidGame(data) {
      return data.keys().hasAll(['title', 'code', 'authorId', 'authorName', 'likes', 'views', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.code is string && data.code.size() > 0 && data.code.size() <= 1000000 &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() > 0 &&
             data.likes is number && data.likes >= 0 &&
             data.views is number && data.views >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid;
    }

    match /games/{gameId} {
      allow read: if true; // Games are public
      allow create: if isAuthenticated() && isValidGame(request.resource.data);
      allow update: if isAuthenticated() && (
        // Author can update title/code
        (request.auth.uid == resource.data.authorId && isValidGame(request.resource.data)) ||
        // Anyone can increment views or likes (with specific logic)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) && 
         request.resource.data.views == resource.data.views + 1) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) && 
         (request.resource.data.likes == resource.data.likes + 1 || request.resource.data.likes == resource.data.likes - 1))
      );
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());

      match /likes/{userId} {
        allow read: if true;
        allow create: if isOwner(userId) && request.resource.data.gameId == gameId;
        allow delete: if isOwner(userId);
      }
    }
  }
}
