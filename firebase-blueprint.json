{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user game progress and stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "name": { "type": "string", "description": "Player name" },
        "money": { "type": "number", "description": "Current money" },
        "trophies": { "type": "number", "description": "Total trophies" },
        "kills": { "type": "number", "description": "Total kills" },
        "deaths": { "type": "number", "description": "Total deaths" },
        "unlockedSkins": { "type": "array", "items": { "type": "string" }, "description": "List of unlocked skins" },
        "currentSkin": { "type": "string", "description": "Currently equipped skin" },
        "friends": { "type": "array", "items": { "type": "string" }, "description": "List of friend UIDs" },
        "friendRequests": { "type": "array", "items": { "type": "string" }, "description": "List of incoming friend request UIDs" }
      },
      "required": ["uid", "name", "money", "trophies", "kills", "deaths"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile data"
    }
  }
}
